# .streamlit/secrets.toml
# Used by Streamlit Cloud for secret management.
# DO NOT commit this file — it is in .gitignore.
# For local dev, prefer a project `.env` with HF_API_TOKEN=... (loaded by app.py)
# or set the variable in your shell, e.g. PowerShell:
#   $env:HF_API_TOKEN="hf_your_token_here"

HF_API_TOKEN = "hf_your_token_here"
